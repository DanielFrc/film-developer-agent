# Copy to .env and adjust for your machine:
#   cp .env.example .env

# Data
DATA_PATH=data/

# LLM — local Ollama (default)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT=600

# LLM — OpenAI (optional; set LLM_PROVIDER=openai)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Recipe cache / prompts
PROMPT_VERSION=3
RECIPE_LANGUAGE=en
# Server default when API/CLI omit language (en or es). Web UI uses Preferences.
MAX_EXTRA_CONTEXT_LENGTH=500
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1200
SESSION_SUMMARY_MAX_TOKENS=500

# API CORS (comma-separated origins for Vite dev server)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Scrape tuning (used by digitaltruth_scrapper)
MAX_WORKERS=10
SCRAPE_DELAY_MIN=0.5
SCRAPE_DELAY_MAX=1.5
SCRAPE_MAX_RETRIES=3
